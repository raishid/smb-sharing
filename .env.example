NETBIOS_NAME=printserver
# Una o varias impresoras: nombre:ip:cola_o_puerto
# Si el tercer campo es número → AppSocket/socket (ej: 9100)
# Si el tercer campo es texto  → LPD/LPR (ej: lp, COMANDAS)
# Ejemplos:
#   AppSocket: sotano:192.168.16.242:9100
#   LPD:       sotano:192.168.16.242:lp
PRINTERS=sotano:192.168.16.242:9100|piso1:192.168.16.243:9100
IP_CONTAINER=192.168.16.231
DNS_SERVER=192.168.16.200